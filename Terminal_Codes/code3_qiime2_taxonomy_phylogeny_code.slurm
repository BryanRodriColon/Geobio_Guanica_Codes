#!/bin/bash
#SBATCH --job-name=Tax_phylo_BRC
#SBATCH --partition=eeb
#SBATCH --mail-type=END,FAIL
#SBATCH --mail-user=b324r112@ku.edu
#SBATCH --ntasks=2
#SBATCH --cpus-per-task=4               # Increase threads
#SBATCH --mem=64G                       # Increase memory
#SBATCH --time=6:00:00                  # Increase runtime

# Define timestamp
TIMESTAMP=$(date +%Y-%m-%d_%H-%M-%S)

# Redirect output and error logs to a file with a timestamp
LOGFILE="Tax_phylogeny_${TIMESTAMP}.log"
exec > $LOGFILE 2>&1

mv $LOGFILE logs/

# Create the "logs" folder if it doesn't exist
mkdir -p logs

# Redirect output and error logs to the "logs" folder with a timestamp
LOGFILE="logs/Tax_phylogeny_${TIMESTAMP}.log"
exec > "$LOGFILE" 2>&1



# Load Conda environment
module load conda
conda activate qiime2-amplicon-2024.10


# Define variables from command-line arguments
qiimedatapath="/kuhpc/work/sturm/b324r112/PROJECTS/Puerto_Rico/Amplicon/Sci_Rep_data_2019"
#classifierpath="/kuhpc/work/sturm/b324r112/PROJECTS/Puerto_Rico/Amplicon/Sci_Rep_data_2019/00_ref_files/SILVA_132.8/classifiers"
#dada2folder="03_denoise_files"



filenames="SciRep-Data-postdada2"

echo "QIIME data path: $qiimedatapath"
#echo "classifier path: $classifierpath"
#echo "DADA2 output folder: $dada2folder"


# Change directory to QIIME data path
cd "$qiimedatapath" || { echo "Failed to change directory to $qiimedatapath"; exit 1; }


echo "starting taxonomy assignment portion"

# Create taxonomy folder to store taxonomy assignment data
mkdir -p 04_taxonomy_assig_files
echo "Created directory 04_taxonomy_assig_files"


# Assign taxonomy using the naïve Bayesian classifier trained with trained SILVA 132.8 database
echo "Running marker specific, feature-classifier classify-sklearn..."
qiime feature-classifier classify-sklearn \
--i-classifier "00_ref_files/SILVA_132.8/classifiers/silva-138.2-ssu-nr99-515fy-806ry-classifier.qza" \
--i-reads "03_denoise_files/SciRep-Data-dada2-rep-seqs.qza" \
--o-classification "04_taxonomy_assig_files/$filenames._spec_marker_taxonomy.qza" \
--verbose
echo "Marker specific, Feature-classifier classify-sklearn completed!"


echo "taxonomy done!"

#####################Aligmnment#####################

echo "starting alignment portion"

# Create directory to store alignment files
mkdir -p 05_alignment_files
echo "Created directory 05_alignment_files"

# Align representative sequences generated by DADA2 using the MAFFT aligner
echo "Running alignment mafft..."
qiime alignment mafft \
--i-sequences "03_denoise_files/SciRep-Data-dada2-rep-seqs.qza" \
--p-n-threads 2 \
--o-alignment "05_alignment_files/$filenames._mafft_align.qza" \
--verbose
echo "Alignment mafft completed"

# Masking the above generated alignment
echo "Running alignment mask..."
qiime alignment mask \
--i-alignment "05_alignment_files/$filenames._mafft_align.qza" \
--o-masked-alignment "05_alignment_files/$filenames._mafft_align_mask.qza" \
--verbose
echo "Alignment mask completed"

echo "Aligment done!"


##################Phylogenetic Treas#######################

echo "starting tree reconstruction"

# Creating directory to store alignment files
mkdir -p 06_phylogeny_files
echo "Created directory 06_phylogeny_files"

# Generating phylogenetic tree with fasttree using the masked alignment 
echo "Running phylogeny fasttree..."
qiime phylogeny fasttree \
--i-alignment "05_alignment_files/$filenames._mafft_align_mask.qza" \
--p-n-threads 1 \
--o-tree "06_phylogeny_files/$filenames._fasttree_phy.qza" \
--verbose
echo "Phylogeny fasttree completed"

# Midpoint rooting phylogenetic tree
echo "Running phylogeny midpoint-root..."
qiime phylogeny midpoint-root \
--i-tree "06_phylogeny_files/$filenames._fasttree_phy.qza" \
--o-rooted-tree "06_phylogeny_files/$filenames._fasttree_mdpt_root_phy.qza" 
echo "Phylogeny midpoint-root completed"


##############exporting files##############################

echo "exporting	files..."

# Creating directories in prep for exporting data from QIIME2
mkdir -p 07_export_data
echo "Created export directory"

#Create subexport folders within the 07_export_data
mkdir -p {07_export_data/deonise_export_files,07_export_data/taxonomy_export_files,07_export_data/phylogeny_export_files}
echo "Created export sub-directories"


# Exporting 16S ASV Table. Make sure to rename table immediately after exporting
echo "Exporting 16S ASV Table..."
qiime tools export --input-path "03_denoise_files/SciRep-Data-dada2-table.qza" --output-path 07_export_data/deonise_export_files/
mv 07_export_data/03_denoise_files/feature-table.biom 07_export_data/03_denoise_files/050525_feature-table.biom
cp 07_export_data/03_denoise_files/050525_feature-table.biom 07_export_data/biom_manipulation/
echo "16S ASV Table exported"

# Exporting 16S Representative sequences. Make sure to rename file immediately after exporting
echo "Exporting 16S Representative sequences..."
qiime tools export --input-path "03_denoise_files/SciRep-Data-dada2-rep-seqs.qza" --output-path 07_export_data/deonise_export_files/
echo "16S Representative sequences exported"

# Exporting 16S taxonomy with marker-specific classifier. Make sure to rename file immediately after exporting
echo "Exporting 16S taxonomy (specific-marker)......"
qiime tools export --input-path "04_taxonomy_assig_files/$filenames._spec_marker_taxonomy.qza" --output-path 07_export_data/taxonomy_export_files/
mv 07_export_data/taxonomy_export_files/taxonomy.tsv 07_export_data/taxonomy_export_files/050525_taxonomy.tsv
cp 07_export_data/taxonomy_export_files/050525_taxonomy.tsv 07_export_data/biom_manipulation/
echo "16S taxonomy exported"


# Exporting 16S phylogeny. Make sure to rename file immediately after exporting
echo "Exporting 16S phylogeny..."
qiime tools export --input-path "06_phylogeny_files/$filenames._fasttree_mdpt_root_phy.qza" --output-path 07_export_data/phylogeny_export_files/
mv 07_export_data/phylogeny_export_files/tree.nwk 07_export_data/phylogeny_export_files/050525_tree.nwk
echo "16S phylogeny exported"

echo "DONE!"

